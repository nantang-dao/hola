PORT=4000

# OAuth app credentials — register at http://localhost:3001/oauth/apps
SEMI_CLIENT_ID=
SEMI_CLIENT_SECRET=

# Semi URLs (local dev defaults; override for production)
SEMI_FRONTEND_URL=http://localhost:3001
SEMI_BACKEND_URL=http://localhost:3000

# Must match the redirect URI registered in the OAuth app
REDIRECT_URI=http://localhost:4000/callback

# Secret for signing session cookies — use a strong random value in production
# Generate with: openssl rand -hex 32
SESSION_SECRET=
